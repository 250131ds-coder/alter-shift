datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

generator client {
  provider = "prisma-client-js"
}

// =========================
// 1. 店舗
// =========================
model Store {
  id               Int               @id @default(autoincrement())
  name             String
  areaName         String?           @map("area_name")
  managerName      String?           @map("manager_name")
  createdAt        DateTime          @default(now()) @map("created_at")
  updatedAt        DateTime          @updatedAt @map("updated_at")

  staffs           Staff[]
  eventTemplates   EventTemplate[]
  storeEvents      StoreEvent[]
  shifts           Shift[]
  helpChatsFrom    HelpChat[]        @relation("FromStore")
  helpChatsTo      HelpChat[]        @relation("ToStore")
  aiGenerationLogs AiGenerationLog[]

  @@map("store")
}

// =========================
// 2. スタッフ
// =========================
model Staff {
  id        Int          @id @default(autoincrement())
  storeId   Int          @map("store_id")
  name      String
  role      String
  email     String?
  phone     String?
  createdAt DateTime     @default(now()) @map("created_at")
  updatedAt DateTime     @updatedAt @map("updated_at")

  store     Store        @relation(fields: [storeId], references: [id], onDelete: Cascade)
  skills    StaffSkill[]
  shifts    Shift[]

  @@index([storeId], map: "idx_staff_store_id")
  @@map("staff")
}

// =========================
// 3. スキル
// =========================
model Skill {
  id                        Int                        @id @default(autoincrement())
  name                      String                     @unique(map: "skill_name_unique")
  createdAt                 DateTime                   @default(now()) @map("created_at")

  staffs                    StaffSkill[]
  eventTemplateRequirements EventTemplateRequirement[]

  @@map("skill")
}

// =========================
// 4. スタッフ × スキル
// =========================
model StaffSkill {
  staffId Int   @map("staff_id")
  skillId Int   @map("skill_id")

  staff   Staff @relation(fields: [staffId], references: [id], onDelete: Cascade)
  skill   Skill @relation(fields: [skillId], references: [id], onDelete: Cascade)

  @@id([staffId, skillId])
  @@map("staff_skill")
}

// =========================
// 5. イベントテンプレート
// =========================
model EventTemplate {
  id           Int                        @id @default(autoincrement())
  storeId      Int                        @map("store_id")
  name         String
  createdAt    DateTime                   @default(now()) @map("created_at")
  updatedAt    DateTime                   @updatedAt @map("updated_at")

  store        Store                      @relation(fields: [storeId], references: [id], onDelete: Cascade)
  requirements EventTemplateRequirement[]
  storeEvents  StoreEvent[]

  @@unique([storeId, name], map: "event_template_store_id_name_unique")
  @@index([storeId], map: "idx_event_template_store_id")
  @@map("event_template")
}

// =========================
// 6. イベントテンプレート必要人数
// =========================
model EventTemplateRequirement {
  templateId Int           @map("template_id")
  skillId    Int           @map("skill_id")
  count      Int           @default(1)

  template   EventTemplate @relation(fields: [templateId], references: [id], onDelete: Cascade)
  skill      Skill         @relation(fields: [skillId], references: [id], onDelete: Cascade)

  @@id([templateId, skillId])
  @@map("event_template_requirement")
}

// =========================
// 7. 店舗イベント
// =========================
model StoreEvent {
  id         Int            @id @default(autoincrement())
  storeId    Int            @map("store_id")
  date       DateTime       @db.Date
  title      String
  templateId Int?           @map("template_id")
  createdAt  DateTime       @default(now()) @map("created_at")

  store      Store          @relation(fields: [storeId], references: [id], onDelete: Cascade)
  template   EventTemplate? @relation(fields: [templateId], references: [id], onDelete: SetNull)

  @@unique([storeId, date, title], map: "store_event_store_date_title_unique")
  @@index([storeId, date], map: "idx_store_event_store_id_date")
  @@map("store_event")
}

// =========================
// 8. 日別シフト
// =========================
model Shift {
  id            Int            @id @default(autoincrement())
  storeId       Int            @map("store_id")
  staffId       Int            @map("staff_id")
  date          DateTime       @db.Date
  type          String
  startTime     DateTime?      @db.Time @map("start_time")
  endTime       DateTime?      @db.Time @map("end_time")
  status        String         @default("draft")
  createdAt     DateTime       @default(now()) @map("created_at")
  updatedAt     DateTime       @updatedAt @map("updated_at")

  store         Store          @relation(fields: [storeId], references: [id], onDelete: Cascade)
  staff         Staff          @relation(fields: [staffId], references: [id], onDelete: Cascade)
  shiftComments ShiftComment[]

  // 1スタッフ1日1シフト前提
  @@unique([staffId, date], map: "shift_staff_id_date_unique")

  // APIで多用する検索向け
  @@index([storeId, date], map: "idx_shift_store_id_date")
  @@index([staffId, date], map: "idx_shift_staff_id_date")
  @@index([storeId, status, date], map: "idx_shift_store_status_date")

  @@map("shift")
}

// =========================
// 9. シフトコメント
// =========================
model ShiftComment {
  id        Int      @id @default(autoincrement())
  shiftId   Int      @map("shift_id")
  category  String   @default("general")
  comment   String   @db.Text
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  shift     Shift    @relation(fields: [shiftId], references: [id], onDelete: Cascade)

  @@index([shiftId], map: "idx_shift_comment_shift_id")
  @@map("shift_comment")
}

// =========================
// 10. AI自動作成履歴
// =========================
model AiGenerationLog {
  id           Int      @id @default(autoincrement())
  storeId      Int      @map("store_id")
  targetDate   DateTime @db.Date @map("target_date")
  status       String   @default("success")
  errorMessage String?  @db.Text @map("error_message")
  createdAt    DateTime @default(now()) @map("created_at")

  store        Store    @relation(fields: [storeId], references: [id], onDelete: Cascade)

  @@index([storeId, targetDate], map: "idx_ai_generation_log_store_target_date")
  @@map("ai_generation_log")
}

// =========================
// 11. ヘルプ相談チャット
// =========================
model HelpChat {
  id          Int       @id @default(autoincrement())
  fromStoreId Int       @map("from_store_id")
  toStoreId   Int?      @map("to_store_id")
  message     String    @db.Text
  isAi        Boolean   @default(false) @map("is_ai")
  status      String    @default("draft")
  sentAt      DateTime? @map("sent_at")
  createdAt   DateTime  @default(now()) @map("created_at")
  updatedAt   DateTime  @updatedAt @map("updated_at")

  fromStore   Store     @relation("FromStore", fields: [fromStoreId], references: [id], onDelete: Cascade)
  toStore     Store?    @relation("ToStore", fields: [toStoreId], references: [id], onDelete: Cascade)

  @@index([fromStoreId], map: "idx_help_chat_from_store_id")
  @@index([toStoreId], map: "idx_help_chat_to_store_id")
  @@map("help_chat")
}