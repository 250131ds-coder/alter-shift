datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

generator client {
  provider = "prisma-client-js"
}

// 1. スタッフテーブル
model Staff {
  id        Int          @id @default(autoincrement())
  name      String
  role      String
  contact   String?
  createdAt DateTime     @default(now())
  updatedAt DateTime     @updatedAt
  skills    StaffSkill[]
  shifts    Shift[]      // 追加：シフトとのリレーション
}

// 2. スキルマスタテーブル
model Skill {
  id        Int          @id @default(autoincrement())
  name      String       @unique
  createdAt DateTime     @default(now())
  staffs    StaffSkill[]
}

// 3. 【中間テーブル】スタッフ ⇄ スキル
model StaffSkill {
  staffId Int
  skillId Int
  staff   Staff @relation(fields: [staffId], references: [id], onDelete: Cascade)
  skill   Skill @relation(fields: [skillId], references: [id], onDelete: Cascade)

  @@id([staffId, skillId])
}

// ★追加：4. 店舗イベントテーブル
model StoreEvent {
  id        Int      @id @default(autoincrement())
  date      DateTime @unique // 1日1イベントに制限
  title     String
  createdAt DateTime @default(now())
}

// ★追加：5. 日別シフトテーブル
model Shift {
  id        Int      @id @default(autoincrement())
  staffId   Int
  date      DateTime
  type      String   // '通常', '希望休', '公休' など
  startTime Int      @default(0)
  endTime   Int      @default(0)
  comment   String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  staff     Staff    @relation(fields: [staffId], references: [id], onDelete: Cascade)
}