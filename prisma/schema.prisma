datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

generator client {
  provider = "prisma-client-js"
}

// 1. 店舗テーブル ★新規追加
model Store {
  id               Int               @id @default(autoincrement())
  name             String
  areaName         String?
  managerName      String?
  createdAt        DateTime          @default(now())
  updatedAt        DateTime          @updatedAt
  staffs           Staff[]
  eventTemplates   EventTemplate[]
  storeEvents      StoreEvent[]
  shifts           Shift[]
  helpChatsFrom    HelpChat[]        @relation("FromStore")
  helpChatsTo      HelpChat[]        @relation("ToStore")
  aiGenerationLogs AiGenerationLog[]
}

// 2. スタッフテーブル
model Staff {
  id        Int          @id @default(autoincrement())
  storeId   Int
  name      String
  role      String
  email     String?
  phone     String?
  createdAt DateTime     @default(now())
  updatedAt DateTime     @updatedAt
  store     Store        @relation(fields: [storeId], references: [id], onDelete: Cascade)
  skills    StaffSkill[]
  shifts    Shift[]
}

// 3. スキルマスタテーブル
model Skill {
  id                        Int                        @id @default(autoincrement())
  name                      String                     @unique(map: "Skill_name_unique")
  createdAt                 DateTime                   @default(now())
  staffs                    StaffSkill[]
  eventTemplateRequirements EventTemplateRequirement[]
}

// 4. スタッフ ⇄ スキル 中間テーブル
model StaffSkill {
  staffId Int
  skillId Int
  staff   Staff @relation(fields: [staffId], references: [id], onDelete: Cascade)
  skill   Skill @relation(fields: [skillId], references: [id], onDelete: Cascade)

  @@id([staffId, skillId])
}

// 5. イベントテンプレートテーブル
model EventTemplate {
  id           Int                        @id @default(autoincrement())
  storeId      Int
  name         String
  createdAt    DateTime                   @default(now())
  updatedAt    DateTime                   @updatedAt
  store        Store                      @relation(fields: [storeId], references: [id], onDelete: Cascade)
  requirements EventTemplateRequirement[]
  storeEvents  StoreEvent[]

  @@unique([storeId, name], map: "EventTemplate_storeId_name_unique")
}

// 6. イベントテンプレート必要人数テーブル
model EventTemplateRequirement {
  templateId Int
  skillId    Int
  count      Int           @default(1)
  template   EventTemplate @relation(fields: [templateId], references: [id], onDelete: Cascade)
  skill      Skill         @relation(fields: [skillId], references: [id], onDelete: Cascade)

  @@id([templateId, skillId])
}

// 7. 店舗イベントテーブル
model StoreEvent {
  id         Int            @id @default(autoincrement())
  storeId    Int
  date       DateTime       @db.Date
  title      String
  templateId Int?
  createdAt  DateTime       @default(now())
  store      Store          @relation(fields: [storeId], references: [id], onDelete: Cascade)
  template   EventTemplate? @relation(fields: [templateId], references: [id], onDelete: SetNull)

  @@unique([storeId, date, title], map: "StoreEvent_storeId_date_title_unique")
}

// 8. 日別シフトテーブル
model Shift {
  id            Int            @id @default(autoincrement())
  storeId       Int
  staffId       Int
  date          DateTime       @db.Date
  type          String
  startTime     DateTime?      @db.Time
  endTime       DateTime?      @db.Time
  status        String         @default("draft")
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt
  store         Store          @relation(fields: [storeId], references: [id], onDelete: Cascade)
  staff         Staff          @relation(fields: [staffId], references: [id], onDelete: Cascade)
  shiftComments ShiftComment[]

  @@unique([staffId, date], map: "Shift_staffId_date_unique")
}

// 9. シフトコメントテーブル ★新規追加
model ShiftComment {
  id        Int      @id @default(autoincrement())
  shiftId   Int
  category  String   @default("general")
  comment   String   @db.Text
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  shift     Shift    @relation(fields: [shiftId], references: [id], onDelete: Cascade)
}

// 10. AI自動作成履歴テーブル ★新規追加
model AiGenerationLog {
  id           Int      @id @default(autoincrement())
  storeId      Int
  targetDate   DateTime @db.Date
  status       String   @default("success")
  errorMessage String?  @db.Text
  createdAt    DateTime @default(now())
  store        Store    @relation(fields: [storeId], references: [id], onDelete: Cascade)
}

// 11. ヘルプ相談チャットテーブル
model HelpChat {
  id          Int       @id @default(autoincrement())
  fromStoreId Int
  toStoreId   Int?
  message     String    @db.Text
  isAi        Boolean   @default(false)
  status      String    @default("draft")
  sentAt      DateTime?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  fromStore   Store     @relation("FromStore", fields: [fromStoreId], references: [id], onDelete: Cascade)
  toStore     Store?    @relation("ToStore", fields: [toStoreId], references: [id], onDelete: Cascade)
}